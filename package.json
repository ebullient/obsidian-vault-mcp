{
  "name": "obsidian-vault-mcp",
  "version": "0.9.1",
  "description": "MCP server connecting Open WebUI, Claude Desktop, and other LLMs to your vault.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "fix": "npx @biomejs/biome check --write ./src",
    "format": "npx @biomejs/biome format ./src",
    "eslint": "npx eslint",
    "lint": "npx @biomejs/biome lint ./src",
    "prebuild": "npx @biomejs/biome check ./src",
    "build": "node esbuild.config.mjs production",
    "postbuild": "cp -v manifest.json README.md build",
    "preversion": "npm run build",
    "version": "auto-changelog -p",
    "brat-notes": "run() { auto-changelog --stdout --hide-credit --hide-empty-releases --template .github/changelog.hbs -v $1 --starting-version $1  > release-notes.md; }; run",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "obsidian-md",
    "obsidian-plugin",
    "obsidian-md-plugin",
    "mcp",
    "model-context-protocol"
  ],
  "author": "ebullient",
  "repository": "github.com:ebullient/obsidian-vault-mcp",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/moment": "^2.13.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/parser": "^8.59.4",
    "auto-changelog": "^2.5.1",
    "esbuild": "^0.28.0",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "happy-dom": "^20.9.0",
    "obsidian": "^1.13.1",
    "obsidian-test-mocks": "^2.0.3",
    "tslib": "^2.8.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "fastify": "^5.2.0",
    "obsidian-daily-notes-interface": "^0.9.5"
  },
  "overrides": {
    "glob": "13.0.6",
    "minimatch": "10.2.3",
    "shell-quote": "1.8.4"
  },
  "auto-changelog": {
    "backfillLimit": false,
    "commitLimit": false,
    "ignoreCommitPattern": "(🔖|🔨|🧹|changelog|release|Update README).*",
    "replaceText": {
      "([;.,] [rR]esolves) #\\d+\\.?\\s*$": "$1",
      "([;.,] [Ff]ixes) #\\d+\\.?\\s*$": "$1"
    }
  }
}
